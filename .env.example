# VeilX — environment (all optional)
#
# Copy to `.env` and fill in. The app runs without any of these:
#   - WalletConnect falls back to a placeholder projectId (injected wallets
#     like MetaMask still work; only WalletConnect-based wallets need a real id).
#   - RPC URLs default to public endpoints.

# WalletConnect / Reown project id — enables WalletConnect wallets.
# Get one free at https://cloud.reown.com
VITE_WALLETCONNECT_PROJECT_ID=

# Optional custom RPC endpoints (default to public nodes if unset).
VITE_SEPOLIA_RPC_URL=
VITE_MAINNET_RPC_URL=
